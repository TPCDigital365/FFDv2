# ─── Database ─────────────────────────────────────────────────────────────────
# Azure Database for PostgreSQL - Flexible Server
DATABASE_URL="postgresql://ffdadmin:YOUR_PASSWORD@utlc-ffd-db.postgres.database.azure.com:5432/ffd?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_SECRET"
NEXTAUTH_URL="https://ffd.utlc.co.th"

# ─── Azure AD (Microsoft Entra ID) ───────────────────────────────────────────
AZURE_AD_CLIENT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
AZURE_AD_CLIENT_SECRET="YOUR_CLIENT_SECRET"
AZURE_AD_TENANT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME="utlcffddocs"
AZURE_STORAGE_ACCOUNT_KEY="YOUR_STORAGE_KEY"
AZURE_STORAGE_CONTAINER="ffd-documents"

# ─── Yeeflow Webhook ──────────────────────────────────────────────────────────
YEEFLOW_WEBHOOK_SECRET="REPLACE_WITH_STRONG_SECRET"

NODE_ENV="production"
