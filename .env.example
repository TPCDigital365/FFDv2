# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Transaction pooler — port 6543, ใช้กับ Vercel (runtime queries)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=ffdv2_dev"

# Direct connection — port 5432, ใช้กับ prisma migrate deploy เท่านั้น
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres?schema=ffdv2_dev"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_SECRET"
# Local development: http://localhost:3000
# Vercel production: https://ffdv2-dev.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ─── Azure AD (Microsoft Entra ID) ───────────────────────────────────────────
AZURE_AD_CLIENT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
AZURE_AD_CLIENT_SECRET="YOUR_CLIENT_SECRET"
AZURE_AD_TENANT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ─── Azure Blob Storage ───────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME="utlcffddocs"
AZURE_STORAGE_ACCOUNT_KEY="YOUR_STORAGE_KEY"
AZURE_STORAGE_CONTAINER="ffd-documents"

# ─── Yeeflow Webhook ──────────────────────────────────────────────────────────
YEEFLOW_WEBHOOK_SECRET="REPLACE_WITH_STRONG_SECRET"

NODE_ENV="production"
